import { DynamicStructuredTool, StructuredToolInterface } from '@langchain/ core/tools';
import type { RunnableConfig } from '@langchain/ core/runnables';
import { AIMessage, ToolCall } from '@langchain/ core/messages';
import { z } from 'zod';
import { callLlm } from '../../../model/llm. js';
import { formatToolResult } from '../../ types. js';
import { getCurrentDate } from '../../../ agent/ prompts. js';
import { withTimeout, SUB_OTOOL_ TIMEOUT_ MS } from '../utils. js';

import { getAStockPrice, getAStockPrices } from './ a- stock- price. js';
import { getAStockMetrics } from './ a- stock- metrics. js';
import { getAStockIncome } from './ a- stock- income. js';
import { getAStockBalance } from './ a- stock- balance. js';
import { getAStockCashflow } from './ a- stock- cashflow. js';
import { getAStockIndicator } from './ a- stock- indicator. js';
import { getAStockCompany } from './ a- stock- company. js';

const A_ Stock_Stock_Stock_Stock_Stock_Stock_Stock_Stock_ FINANCIALS_ DESCRIPTION = `
Intelligent meta- tool for retrieving A- share (Chinese stock) financial data. Takes a natural language query and automatically routes to appropriate A- share financial data tools.

## When to Use
- A- share stock tickers: 600000 (Shanghai), 00xxxx (Shenzhen), 300xxx (ChiNext)
- Company facts (exchange, chairman, registered capital, province)
- Company financials (income statements, balance sheets, cash flow)
- Financial metrics and key ratios (P/ E ratio, market cap, ROE, margins)
- Historical metrics and trend analysis

## When NOT to Use
- US stocks (use get_financials instead)
- Hong Kong stocks
- General web searches or non- financial topics
- Questions that don't require external financial data
`. trim();

const A_ Stock_Stock_Stock_Stock_Stock_Stock_Stock_Stock_ FINANCE_ TOOLS: StructuredToolInterface[] = [
  getAStockPrice,
  getAStockPrices,
  getAStockMetrics,
  getAStockIncome,
  getAStockBalance,
  getAStockCashflow,
  getAStockIndicator,
  getAStockCompany,
];

const A_ Stock_Stock_Stock_Stock_Stock_Stock_Stock_Stock_ TOOL_ MAP: Map<string, StructuredToolInterface> = new Map(
  A_ Stock_Stock_Stock_Stock_Stock_Stock_Stock_Stock_ FINANCE_ TOOLS. map((t) => [t. name, t])
);

function formatSubToolName(name: string): string {
  return name. split('_'). map((w) => w. charAt(0). toUpperCase() + w. slice(1)). join(' ');
}

function buildRouterPrompt(): string {
  return `You are an A- share financial data routing assistant. Tushare API expert.
Current date: ${getCurrentDate()}

Given a user's natural language query about A- share financial data, call the appropriate A- share financial tool(s).

## A- share Ticker Rules
- 6xxxxx → Shanghai Stock Exchange (sh. 6xxxxx)
- 00xxxx → Shenzhen Stock Exchange (sz. 00xxxx)
- 30xxxx → ChiNext (sz. 30xxxx)
- 688xxx → STAR Market (sh. 688xxx)

Examples: 600000 = sh. 600000, 00 0001 = sz. 00 0001, 300001 = sz. 300001

## Tool Selection Guidelines
1. For current/ latest stock price → get_ a_ stock_ price
2. For historical prices → get_ a_ stock_ prices
3. For P/ E, P/ B, market cap, turnover → get_ a_ stock_ metrics
4. For revenue, net profit, EPS → get_ a_ stock_ income
5. For assets, liabilities, equity → get_ a_ stock_ balance
6. For cash flow → get_ a_ stock_ cashflow
7. For ROE, ROA, margins → get_ a_ stock_ indicator
8. For company info → get_ a_ stock_ company

Call the appropriate tool(s) now.`;
}

const GetAStockFinancialsInputSchema = z. object({
  query: z. string(). describe('Natural language query about A- share financial data'),
});

export function createGetAStockFinancials(model: string): DynamicStructuredTool {
  return new DynamicStructuredTool({
    name: 'get_ a_ stock_ financials',
    description: A_ Stock_Stock_Stock_Stock_Stock_Stock_Stock_Stock_ FINANCIALS_ DESCRIPTION,
    schema: GetAStockFinancialsInputSchema,
    func: async (input, _runManager, config?: RunnableConfig) => {
      const onProgress = config?. metadata?. onProgress as ((msg: string) => void) | undefined;

      onProgress?.('Routing A- share query...');
      const { response } = await callLlm(input. query, {
        model,
        systemPrompt: buildRouterPrompt(),
        tools: A_ Stock_Stock_Stock_Stock_Stock_Stock_Stock_Stock_ FINANCE_ TOOLS,
      });
      const aiMessage = response as AIMessage;

      const toolCalls = aiMessage. tool_ calls as ToolCall[];
      if (!toolCalls || toolCalls. length === 0) {
        return formatToolResult({ error: 'No tools selected for query' }, []);
      }

      const toolNames = [... new Set(toolCalls. map((tc) => formatSubToolName(tc. name)))];
      onProgress?.(`Fetching from ${toolNames. join(', ')}...`);

      const results = await Promise. all(
        toolCalls. map(async (tc) => {
          try {
            const tool = A_ Stock_Stock_Stock_Stock_Stock_Stock_Stock_Stock_ TOOL_ MAP. get(tc. name);
            if (!tool) {
              throw new Error(`Tool '${tc. name}' not found`);
            }
            const rawResult = await withTimeout(tool. invoke(tc. args as any), SUB_OTOOL_Timeout_ MS, tc. name);
            const result = typeof rawResult === 'string' ? rawResult : JSON. stringify(rawResult);
            const parsed = JSON. parse(result);
            return { tool: tc. name, args: tc. args, data: parsed, error: null };
          } catch (error) {
            return {
              tool: tc. name,
              args: tc. args,
              data: null,
              error: error instanceof Error ? error. message : String(error),
            };
          }
        })
      );

      const successfulResults = results. filter((r) => r. error === null);
      const failedResults = results. filter((r) => r. error !== null);

      const combinedData: Record<string, unknown> = {};

      for (const result of successfulResults) {
        const ticker = (result. args as Record<string, unknown>). ticker as string | undefined;
        const key = ticker ? `${result. tool}_${ticker}` : result. tool;
        combinedData[key] = result. data;
      }

      if (failedResults. length > 0) {
        combinedData._errors = failedResults. map((r) => ({
          tool: r. tool,
          args: r. args,
          error: r. error,
        }));
      }

      return formatToolResult(combinedData, []);
    },
  });
}